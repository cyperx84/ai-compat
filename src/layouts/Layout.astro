---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Compatibility rankings for AI models, coding harnesses, and high-signal combinations.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | ai-compat.info</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="shell-width header-inner">
          <div class="brand-block">
            <a href="/" class="brand">ai-compat.info</a>
            <p class="brand-copy">Shared data for site, API, CLI, and agent skills.</p>
          </div>
          <nav class="site-nav" aria-label="Primary">
            <a href="/matrix">Matrix</a>
            <a href="/tiers">Tiers</a>
            <a href="/best">Best For</a>
            <a href="/models">Models</a>
            <a href="/harnesses">Harnesses</a>
            <a href="/combos">Combos</a>
            <a href="/docs">Docs</a>
            <a href="/about">About</a>
          </nav>
        </div>
      </header>

      <main class="page shell-width">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="shell-width footer-inner">
          <div>
            <strong>ai-compat.info</strong>
            <p>Shared structured compatibility data for agent tooling decisions.</p>
          </div>
          <div class="footer-links">
            <a href="/docs">Docs</a>
            <a href="/about">About</a>
            <a href="/api/models.json">API</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --font-sans: "Instrument Sans", "Avenir Next", "Segoe UI", sans-serif;
    --font-mono: "IBM Plex Mono", "SFMono-Regular", "Consolas", monospace;
    --space-1: 0.4rem;
    --space-2: 0.7rem;
    --space-3: 1rem;
    --space-4: 1.4rem;
    --space-5: 1.9rem;
    --space-6: 2.6rem;
    --space-7: 3.6rem;
    --radius-sm: 14px;
    --radius-md: 22px;
    --radius-lg: 28px;
    --shadow-sm: 0 14px 30px rgba(17, 22, 32, 0.08);
    --shadow-lg: 0 28px 70px rgba(17, 22, 32, 0.14);
    --bg: #f4f5f8;
    --bg-elevated: rgba(255, 255, 255, 0.78);
    --bg-strong: rgba(255, 255, 255, 0.92);
    --panel-edge: rgba(56, 72, 99, 0.14);
    --text: #162033;
    --muted: #59667d;
    --muted-strong: #3b495f;
    --accent: #0e7c66;
    --accent-strong: #0b5d4d;
    --accent-soft: rgba(14, 124, 102, 0.12);
    --secondary: #245fb2;
    --secondary-soft: rgba(36, 95, 178, 0.12);
    --ok: #1f7a59;
    --warn: #9a6a10;
    --danger: #8e3a35;
    --tier-s: #0b6d5a;
    --tier-a: #17628b;
    --tier-b: #8b6a18;
    --tier-c: #7a4950;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0e141d;
      --bg-elevated: rgba(18, 26, 38, 0.82);
      --bg-strong: rgba(20, 30, 43, 0.94);
      --panel-edge: rgba(154, 176, 214, 0.16);
      --text: #eef3fb;
      --muted: #b4c0d4;
      --muted-strong: #d0dae9;
      --accent: #5fd1b5;
      --accent-strong: #8fe0cb;
      --accent-soft: rgba(95, 209, 181, 0.14);
      --secondary: #7eb0ff;
      --secondary-soft: rgba(126, 176, 255, 0.14);
      --shadow-sm: 0 18px 36px rgba(0, 0, 0, 0.22);
      --shadow-lg: 0 30px 80px rgba(0, 0, 0, 0.34);
      --ok: #70dbab;
      --warn: #e2bf68;
      --danger: #eb9a8f;
      --tier-s: #5fd1b5;
      --tier-a: #7eb0ff;
      --tier-b: #e2bf68;
      --tier-c: #eb9a8f;
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: var(--font-sans);
    color: var(--text);
    line-height: 1.65;
    background:
      radial-gradient(circle at top left, rgba(36, 95, 178, 0.18), transparent 28%),
      radial-gradient(circle at top right, rgba(14, 124, 102, 0.18), transparent 32%),
      linear-gradient(180deg, color-mix(in srgb, var(--bg) 92%, white 8%) 0%, var(--bg) 100%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .site-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .shell-width {
    width: min(1180px, calc(100vw - 2rem));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: var(--space-3) 0;
    backdrop-filter: blur(18px);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border-bottom: 1px solid rgba(127, 145, 176, 0.12);
  }

  .header-inner,
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .brand-block {
    display: grid;
    gap: 0.15rem;
  }

  .brand,
  .site-nav a,
  .eyebrow,
  .pill,
  .tag,
  .stat-label,
  .score-chip,
  .back-link,
  .footer-links a,
  .table-meta,
  .tier-badge {
    font-family: var(--font-mono);
  }

  .brand {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .brand-copy {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .site-nav a,
  .footer-links a,
  .button,
  .button-ghost {
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      box-shadow 180ms ease;
  }

  .site-nav a {
    padding: 0.5rem 0.82rem;
    border-radius: 999px;
    border: 1px solid transparent;
    color: var(--muted-strong);
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    border-color: var(--panel-edge);
    background: var(--bg-strong);
    transform: translateY(-1px);
  }

  .page {
    flex: 1;
    padding: var(--space-6) 0 var(--space-7);
  }

  .hero,
  .section-card,
  .detail-card,
  .matrix-card,
  .list-card,
  .feature-card,
  .tier-section {
    border: 1px solid var(--panel-edge);
    background: var(--bg-elevated);
    backdrop-filter: blur(18px);
    box-shadow: var(--shadow-sm);
    border-radius: var(--radius-md);
  }

  .hero {
    padding: clamp(1.6rem, 4vw, 3rem);
    margin-bottom: var(--space-5);
    box-shadow: var(--shadow-lg);
  }

  .section-stack {
    display: grid;
    gap: var(--space-4);
  }

  .section-card,
  .detail-card,
  .matrix-card,
  .tier-section {
    padding: var(--space-5);
  }

  .detail-header,
  .split-header {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .detail-meta,
  .button-row,
  .stats,
  .meta-row,
  .tag-row,
  .tier-summary {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.76rem;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  h1 {
    font-size: clamp(2.6rem, 5vw, 4.8rem);
    margin-top: var(--space-1);
  }

  h2 {
    font-size: clamp(1.35rem, 2vw, 1.75rem);
    margin-bottom: var(--space-2);
  }

  h3 {
    font-size: 1.05rem;
    margin-bottom: var(--space-2);
  }

  p {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
  }

  .lede {
    max-width: 52rem;
    margin-top: var(--space-3);
    font-size: 1.08rem;
  }

  .button,
  .button-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 2.8rem;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid var(--panel-edge);
    font-weight: 600;
  }

  .button {
    background: linear-gradient(135deg, var(--accent) 0%, var(--secondary) 100%);
    color: white;
    border-color: transparent;
    box-shadow: 0 12px 24px rgba(36, 95, 178, 0.18);
  }

  .button-ghost {
    background: var(--bg-strong);
    color: var(--muted-strong);
  }

  .button:hover,
  .button-ghost:hover,
  .button:focus-visible,
  .button-ghost:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 16px 28px rgba(17, 22, 32, 0.16);
  }

  .stats {
    margin-top: var(--space-4);
  }

  .stat {
    min-width: 8rem;
    padding: var(--space-3);
    border: 1px solid var(--panel-edge);
    border-radius: var(--radius-sm);
    background: var(--bg-strong);
  }

  .stat-value {
    font-size: 1.7rem;
    line-height: 1;
    font-weight: 700;
  }

  .stat-label {
    color: var(--muted);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 0.35rem;
  }

  .grid {
    display: grid;
    gap: var(--space-3);
  }

  .grid.cols-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid.cols-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .list-card,
  .feature-card {
    display: block;
    padding: var(--space-4);
    position: relative;
    overflow: hidden;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease;
  }

  .list-card::after,
  .feature-card::after {
    content: "";
    position: absolute;
    inset: auto -25% -55% 45%;
    height: 10rem;
    background: radial-gradient(circle, var(--accent-soft) 0%, transparent 65%);
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .list-card:hover,
  .feature-card:hover,
  .list-card:focus-visible,
  .feature-card:focus-visible {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--accent) 24%, var(--panel-edge));
    box-shadow: var(--shadow-lg);
  }

  .list-card:hover::after,
  .feature-card:hover::after {
    opacity: 1;
  }

  .list-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .detail-copy {
    margin-top: var(--space-2);
  }

  .pill,
  .tag,
  .tier-badge,
  .score-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    border-radius: 999px;
    min-height: 1.9rem;
    padding: 0 0.7rem;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    border: 1px solid var(--panel-edge);
    background: var(--bg-strong);
    color: var(--muted-strong);
  }

  .pill.recommended,
  .pill.stable,
  .tier-badge.tier-s {
    background: color-mix(in srgb, var(--tier-s) 14%, var(--bg-strong));
    color: var(--tier-s);
  }

  .pill.strong,
  .pill.beta,
  .tier-badge.tier-a {
    background: color-mix(in srgb, var(--tier-a) 14%, var(--bg-strong));
    color: var(--tier-a);
  }

  .pill.active,
  .tier-badge.tier-b {
    background: color-mix(in srgb, var(--tier-b) 16%, var(--bg-strong));
    color: var(--tier-b);
  }

  .pill.experimental,
  .tier-badge.tier-c {
    background: color-mix(in srgb, var(--tier-c) 14%, var(--bg-strong));
    color: var(--tier-c);
  }

  .score-chip {
    min-width: 3.25rem;
    background: linear-gradient(135deg, var(--accent-soft) 0%, var(--secondary-soft) 100%);
    color: var(--muted-strong);
  }

  .score-chip.empty {
    opacity: 0.55;
  }

  .meta-row,
  .tag-row {
    margin-top: var(--space-3);
  }

  .back-link {
    display: inline-flex;
    margin-bottom: var(--space-3);
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .back-link:hover {
    color: var(--text);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.96rem;
  }

  th,
  td {
    text-align: left;
    padding: 0.9rem 0.95rem;
    border-bottom: 1px solid var(--panel-edge);
    vertical-align: top;
  }

  th {
    color: var(--muted-strong);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: color-mix(in srgb, var(--bg-strong) 86%, transparent);
  }

  tbody tr:hover {
    background: color-mix(in srgb, var(--accent-soft) 45%, transparent);
  }

  .table-wrap {
    overflow-x: auto;
    border-radius: var(--radius-sm);
  }

  .table-meta {
    font-size: 0.76rem;
    color: var(--muted);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .site-footer {
    padding: var(--space-5) 0;
    border-top: 1px solid rgba(127, 145, 176, 0.12);
  }

  .site-footer p {
    margin-top: 0.2rem;
    font-size: 0.94rem;
  }

  .footer-links a {
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--panel-edge);
  }

  .footer-links a:hover {
    background: var(--bg-strong);
    transform: translateY(-1px);
  }

  .prose {
    display: grid;
    gap: var(--space-4);
  }

  .prose ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--muted);
  }

  .prose li + li {
    margin-top: 0.45rem;
  }

  @media (max-width: 900px) {
    .header-inner,
    .detail-header,
    .split-header,
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .site-nav {
      justify-content: flex-start;
    }

    .grid.cols-2,
    .grid.cols-3 {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .shell-width {
      width: min(100vw - 1rem, 100%);
    }

    .page {
      padding-top: var(--space-5);
    }

    .hero,
    .section-card,
    .detail-card,
    .matrix-card,
    .tier-section {
      padding: var(--space-4);
    }

    h1 {
      font-size: 2.4rem;
    }

    th,
    td {
      padding: 0.75rem;
    }
  }
</style>
