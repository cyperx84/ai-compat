---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Can I use X with Y? The AI compatibility matrix for coding tools.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — ai-compat.info</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">
          <span class="logo-bracket">[</span>
          <span class="logo-text">ai-compat</span>
          <span class="logo-bracket">]</span>
          <span class="logo-ext">.info</span>
        </a>
        <div class="nav-links">
          <a href="/tools">Tools</a>
          <a href="/models">Models</a>
          <a href="/features">Features</a>
          <a href="/routes">Routes</a>
        </div>
        <div class="nav-status">
          <span class="status-dot"></span>
          <span class="status-text">matrix live</span>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <div class="footer-left">
          <span class="footer-logo">[ai-compat]</span>
          <span class="footer-sep">·</span>
          <span>Can I use X with Y?</span>
        </div>
        <div class="footer-right">
          <a href="https://github.com" target="_blank" rel="noopener">github</a>
          <span class="footer-sep">·</span>
          <span class="footer-version">v0.1.0</span>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0a0a0a;
    --bg-secondary: #111111;
    --bg-tertiary: #1a1a1a;
    --bg-hover: #222222;
    --border: #2a2a2a;
    --border-hover: #3a3a3a;
    --text: #e5e5e5;
    --text-secondary: #999999;
    --text-muted: #666666;
    --accent: #22d3ee;
    --accent-dim: #0e7490;
    --green: #22c55e;
    --yellow: #eab308;
    --blue: #3b82f6;
    --red: #ef4444;
    --gray: #6b7280;
    --font-mono: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --radius: 6px;
    --transition: 150ms ease;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-size: 15px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding: 2rem;
  }

  a {
    color: var(--accent);
    text-decoration: none;
    transition: color var(--transition);
  }

  a:hover {
    color: #67e8f9;
  }

  /* Header */
  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    background: rgba(10, 10, 10, 0.85);
  }

  nav {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.75rem 2rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0;
    white-space: nowrap;
  }

  .logo-bracket {
    color: var(--text-muted);
  }

  .logo-text {
    color: var(--text);
  }

  .logo-ext {
    color: var(--accent);
    margin-left: 2px;
  }

  .nav-links {
    display: flex;
    gap: 0.25rem;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-secondary);
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius);
    transition: all var(--transition);
  }

  .nav-links a:hover {
    color: var(--text);
    background: var(--bg-tertiary);
  }

  .nav-status {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* Footer */
  footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-logo {
    color: var(--text-secondary);
    font-weight: 600;
  }

  .footer-sep {
    color: var(--border);
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-right a {
    color: var(--text-muted);
  }

  .footer-right a:hover {
    color: var(--text);
  }

  .footer-version {
    font-size: 0.65rem;
    background: var(--bg-tertiary);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  /* Utility classes */
  .status-icon {
    font-size: 1rem;
    line-height: 1;
  }

  .mono {
    font-family: var(--font-mono);
  }

  /* Cards */
  .card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: border-color var(--transition);
  }

  .card:hover {
    border-color: var(--border-hover);
  }

  /* Grid layouts */
  .grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .grid-2, .grid-3 {
      grid-template-columns: 1fr;
    }

    nav {
      padding: 0.75rem 1rem;
    }

    main {
      padding: 1rem;
    }
  }

  /* Table styles */
  table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  th {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }

  td {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  tr:hover td {
    background: var(--bg-secondary);
  }

  /* Tags/badges */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    font-weight: 500;
  }

  .badge-supported {
    background: rgba(34, 197, 94, 0.12);
    color: var(--green);
    border: 1px solid rgba(34, 197, 94, 0.25);
  }

  .badge-partial {
    background: rgba(234, 179, 8, 0.12);
    color: var(--yellow);
    border: 1px solid rgba(234, 179, 8, 0.25);
  }

  .badge-unofficial {
    background: rgba(59, 130, 246, 0.12);
    color: var(--blue);
    border: 1px solid rgba(59, 130, 246, 0.25);
  }

  .badge-broken {
    background: rgba(239, 68, 68, 0.12);
    color: var(--red);
    border: 1px solid rgba(239, 68, 68, 0.25);
  }

  .badge-deprecated {
    background: rgba(107, 114, 128, 0.12);
    color: var(--gray);
    border: 1px solid rgba(107, 114, 128, 0.25);
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    background: var(--bg);
  }

  ::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--border-hover);
  }

  /* Detail page header */
  .detail-header {
    margin-bottom: 2rem;
  }

  .detail-header h1 {
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .detail-meta {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .detail-description {
    color: var(--text-secondary);
    margin: 1rem 0 2rem;
    max-width: 700px;
    line-height: 1.7;
  }

  /* Section */
  .section {
    margin-bottom: 2.5rem;
  }

  .section h2 {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section h2::before {
    content: '$';
    color: var(--accent);
    font-weight: 400;
  }

  /* Search */
  .search-container {
    margin-bottom: 1.5rem;
  }

  .search-input {
    width: 100%;
    max-width: 500px;
    padding: 0.6rem 1rem 0.6rem 2.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    outline: none;
    transition: border-color var(--transition);
  }

  .search-input:focus {
    border-color: var(--accent);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-wrapper {
    position: relative;
    display: inline-block;
    width: 100%;
    max-width: 500px;
  }

  .search-wrapper::before {
    content: '⌕';
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-size: 1rem;
    pointer-events: none;
  }

  /* Filter chips */
  .filter-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .filter-chip {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.3rem 0.75rem;
    border-radius: 3px;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition);
  }

  .filter-chip:hover, .filter-chip.active {
    border-color: var(--accent-dim);
    color: var(--accent);
    background: rgba(34, 211, 238, 0.06);
  }

  /* Evidence links */
  .evidence-links {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .evidence-link {
    font-size: 0.65rem;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    background: var(--bg-tertiary);
    color: var(--text-muted);
    border: 1px solid var(--border);
    transition: all var(--transition);
  }

  .evidence-link:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }

  /* Glow effect for hero */
  .hero-glow {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Stats */
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin: 1.5rem 0;
  }

  @media (max-width: 768px) {
    .stat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .stat-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    text-align: center;
  }

  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.25rem;
  }

  /* Back link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--text);
  }
</style>
