---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Shared compatibility data for AI models, coding harnesses, and recommended combinations.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | ai-compat.info</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="header-inner">
          <a href="/" class="brand">ai-compat.info</a>
          <nav class="site-nav" aria-label="Primary">
            <a href="/matrix">Matrix</a>
            <a href="/models">Models</a>
            <a href="/harnesses">Harnesses</a>
            <a href="/combos">Combos</a>
          </nav>
        </div>
      </header>

      <main class="page">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-inner">
          <span>Shared data powers the site, API, and CLI.</span>
          <span class="footer-meta">MVP</span>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f4efe6;
    --bg-panel: rgba(255, 252, 247, 0.78);
    --bg-panel-strong: #fffaf2;
    --ink: #1f1d1a;
    --muted: #635a4f;
    --border: rgba(94, 75, 50, 0.18);
    --accent: #a63d2f;
    --accent-soft: rgba(166, 61, 47, 0.12);
    --accent-strong: #7d2c22;
    --ok: #2b6d4f;
    --warn: #9c6b0e;
    --active: #2f5b91;
    --shadow: 0 18px 40px rgba(74, 57, 33, 0.08);
    --radius: 18px;
    --mono: "IBM Plex Mono", "SFMono-Regular", "Consolas", monospace;
    --sans: "Instrument Sans", "Avenir Next", "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-size: 16px;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(166, 61, 47, 0.1), transparent 28%),
      radial-gradient(circle at top right, rgba(47, 91, 145, 0.1), transparent 30%),
      linear-gradient(180deg, #f8f4eb 0%, var(--bg) 100%);
    color: var(--ink);
    font-family: var(--sans);
    line-height: 1.55;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-shell {
    display: flex;
    min-height: 100vh;
    flex-direction: column;
  }

  .site-header,
  .site-footer {
    padding: 1rem 1.5rem;
  }

  .header-inner,
  .footer-inner,
  .page {
    width: min(1120px, calc(100vw - 2rem));
    margin: 0 auto;
  }

  .header-inner,
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand,
  .site-nav a,
  .eyebrow,
  .label,
  .pill,
  .stat-label,
  .meta-line,
  .footer-meta,
  .back-link {
    font-family: var(--mono);
  }

  .brand {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .site-nav a {
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    color: var(--muted);
    border: 1px solid transparent;
  }

  .site-nav a:hover {
    border-color: var(--border);
    background: rgba(255, 255, 255, 0.5);
  }

  .page {
    flex: 1;
    padding: 1rem 0 4rem;
  }

  .hero,
  .section-card,
  .detail-card,
  .matrix-card,
  .list-card,
  .feature-card {
    background: var(--bg-panel);
    backdrop-filter: blur(18px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .hero {
    padding: 2rem;
    margin-bottom: 1.5rem;
  }

  .section-stack {
    display: grid;
    gap: 1.25rem;
  }

  .section-card,
  .detail-card,
  .matrix-card {
    padding: 1.4rem;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    line-height: 1.1;
  }

  h1 {
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    margin-top: 0.35rem;
  }

  h2 {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  .lede {
    max-width: 44rem;
    font-size: 1.05rem;
    margin-top: 0.8rem;
  }

  .grid {
    display: grid;
    gap: 1rem;
  }

  .grid.cols-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid.cols-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .list-card {
    display: block;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg-panel-strong);
  }

  .list-card:hover {
    border-color: rgba(166, 61, 47, 0.28);
    transform: translateY(-1px);
  }

  .list-head,
  .meta-row,
  .score-row,
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .meta-row,
  .score-row {
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 999px;
    padding: 0.3rem 0.65rem;
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    background: rgba(255, 255, 255, 0.66);
    border: 1px solid var(--border);
    color: var(--ink);
  }

  .pill.recommended {
    color: var(--ok);
    background: rgba(43, 109, 79, 0.1);
  }

  .pill.active {
    color: var(--active);
    background: rgba(47, 91, 145, 0.1);
  }

  .pill.stable {
    color: var(--ok);
  }

  .pill.beta {
    color: var(--warn);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.9rem;
  }

  .tag {
    display: inline-flex;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: rgba(99, 90, 79, 0.08);
    color: var(--muted);
    font-size: 0.78rem;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg-panel-strong);
    font-weight: 600;
  }

  .button.primary {
    color: #fff;
    background: var(--accent);
    border-color: var(--accent);
  }

  .button.primary:hover {
    background: var(--accent-strong);
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .stat {
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.4);
  }

  .stat-value {
    font-size: 1.8rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1rem;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .detail-header {
    display: grid;
    gap: 0.9rem;
    margin-bottom: 1.25rem;
  }

  .detail-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .detail-copy {
    margin-top: 0.9rem;
    max-width: 50rem;
  }

  .matrix-card {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 720px;
  }

  th,
  td {
    padding: 0.8rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  th {
    color: var(--muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--mono);
  }

  .score-chip {
    display: inline-flex;
    justify-content: center;
    min-width: 3.2rem;
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-strong);
    font-family: var(--mono);
    font-weight: 700;
  }

  .score-chip.empty {
    background: rgba(99, 90, 79, 0.08);
    color: var(--muted);
  }

  .footer-inner {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    color: var(--muted);
    font-size: 0.88rem;
  }

  @media (max-width: 860px) {
    .grid.cols-2,
    .grid.cols-3,
    .stats {
      grid-template-columns: 1fr;
    }

    .header-inner,
    .footer-inner {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
