---
import Layout from '../../layouts/Layout.astro';
import { features } from '../../data/features';
import { models } from '../../data/models';
import { STATUS_ICONS, STATUS_LABELS } from '../../data/types';

export function getStaticPaths() {
  return features.map(feature => ({
    params: { id: feature.id },
    props: { feature },
  }));
}

const { feature } = Astro.props;
---

<Layout title={feature.name}>
  <a href="/features" class="back-link">← back to features</a>

  <div class="detail-header">
    <h1>{feature.name}</h1>
    <div class="detail-meta">
      <span class="category-tag">{feature.category}</span>
    </div>
  </div>

  <p class="detail-description">{feature.description}</p>

  <section class="section">
    <h2>Model Support</h2>
    <div class="matrix-scroll">
      <table>
        <thead>
          <tr>
            <th>Model</th>
            <th>Provider</th>
            <th>Status</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          {feature.models.map(compat => {
            const model = models.find(m => m.id === compat.model);
            return (
              <tr>
                <td>
                  {model ? (
                    <a href={`/models/${compat.model}`}>{model.name}</a>
                  ) : (
                    <span class="mono">{compat.model}</span>
                  )}
                </td>
                <td class="text-muted">{model?.provider || '—'}</td>
                <td>
                  <span class={`badge badge-${compat.status}`}>
                    {STATUS_ICONS[compat.status]} {STATUS_LABELS[compat.status]}
                  </span>
                </td>
                <td class="text-muted mono" style="font-size: 0.75rem;">{compat.notes || '—'}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>
</Layout>

<style>
  .category-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    background: rgba(34, 211, 238, 0.1);
    color: var(--accent);
    border: 1px solid rgba(34, 211, 238, 0.25);
    border-radius: 3px;
    font-weight: 500;
  }

  .matrix-scroll {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-secondary);
  }

  .text-muted { color: var(--text-muted); }
</style>
