---
import Layout from "../layouts/Layout.astro";
import { compatData, getRecommendedCombos } from "../data/compat";

const featured = getRecommendedCombos(undefined, 3);
---

<Layout
  title="Find the right AI stack"
  description="Browse a compact compatibility matrix for models, harnesses, and recommended pairings."
>
  <section class="hero">
    <span class="eyebrow">ai-compat.info MVP</span>
    <h1>Find a model + harness combo that actually fits the job.</h1>
    <p class="lede">
      Shared structured data powers the site, JSON endpoints, and the `aicomp`
      CLI. Browse the matrix, inspect detail pages, or pull recommendations by
      use case.
    </p>
    <div class="button-row">
      <a class="button primary" href="/matrix">Open matrix</a>
      <a class="button" href="/api/recommend.json">See JSON recommendations</a>
    </div>
    <div class="stats">
      <div class="stat">
        <div class="stat-value">{compatData.models.length}</div>
        <div class="stat-label">Models</div>
      </div>
      <div class="stat">
        <div class="stat-value">{compatData.harnesses.length}</div>
        <div class="stat-label">Harnesses</div>
      </div>
      <div class="stat">
        <div class="stat-value">{compatData.combos.length}</div>
        <div class="stat-label">Combos</div>
      </div>
      <div class="stat">
        <div class="stat-value">{compatData.usecases.length}</div>
        <div class="stat-label">Use Cases</div>
      </div>
    </div>
  </section>

  <div class="section-stack">
    <section class="section-card">
      <h2>Top combinations</h2>
      <p>Highest-scoring seeded combinations from the shared dataset.</p>
      <div class="grid cols-3" style="margin-top: 1rem;">
        {featured.map((combo) => (
          <a class="list-card" href={`/combos/${combo.slug}`}>
            <div class="list-head">
              <strong>{combo.name}</strong>
              <span class="score-chip">{combo.score.toFixed(1)}</span>
            </div>
            <p class="detail-copy">{combo.description}</p>
            <div class="meta-row">
              <span class={`pill ${combo.status}`}>{combo.status}</span>
              {combo.usecaseDetails && <span class="pill">{combo.usecaseDetails.name}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="grid cols-2">
      <div class="section-card">
        <h2>Models</h2>
        <p>Reasoning, coding, and multimodal models represented in the matrix.</p>
        <div class="grid" style="margin-top: 1rem;">
          {compatData.models.map((model) => (
            <a class="list-card" href={`/models/${model.slug}`}>
              <div class="list-head">
                <strong>{model.name}</strong>
                <span class="pill">{model.provider}</span>
              </div>
              <p class="detail-copy">{model.description}</p>
            </a>
          ))}
        </div>
      </div>

      <div class="section-card">
        <h2>Harnesses</h2>
        <p>Terminal agents, editors, and agent runtimes scored against the same models.</p>
        <div class="grid" style="margin-top: 1rem;">
          {compatData.harnesses.map((harness) => (
            <a class="list-card" href={`/harnesses/${harness.slug}`}>
              <div class="list-head">
                <strong>{harness.name}</strong>
                <span class={`pill ${harness.status}`}>{harness.status}</span>
              </div>
              <p class="detail-copy">{harness.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>
