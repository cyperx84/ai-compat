---
import Layout from "../layouts/Layout.astro";
import {
  compatData,
  getBestCombos,
  getHarnessRankings,
  getModelRankings,
} from "../data/compat";

const featuredCombos = getBestCombos(undefined, 4);
const topModels = getModelRankings().slice(0, 3);
const topHarnesses = getHarnessRankings().slice(0, 3);
---

<Layout
  title="Model and Harness Compatibility"
  description="Ranked compatibility data for AI models, coding harnesses, and recommended combinations."
>
  <section class="hero">
    <span class="eyebrow">Ranked AI Tooling Compatibility</span>
    <h1>Find the right model and harness pair for the way you actually work.</h1>
    <p class="lede">
      `ai-compat.info` tracks realistic pairings across coding, research,
      autonomous, local-first, and budget-driven workflows. The same dataset
      powers this site, JSON endpoints, the `aicomp` CLI, and agent-facing
      skills.
    </p>
    <div class="button-row" style="margin-top: 1.2rem;">
      <a class="button" href="/tiers/models">Model tiers</a>
      <a class="button-ghost" href="/best/coding">Best for coding</a>
      <a class="button-ghost" href="/docs">API + CLI docs</a>
    </div>
    <div class="stats">
      <div class="stat">
        <div class="stat-value">{compatData.models.length}</div>
        <div class="stat-label">Models</div>
      </div>
      <div class="stat">
        <div class="stat-value">{compatData.harnesses.length}</div>
        <div class="stat-label">Harnesses</div>
      </div>
      <div class="stat">
        <div class="stat-value">{compatData.combos.length}</div>
        <div class="stat-label">Ranked Combos</div>
      </div>
      <div class="stat">
        <div class="stat-value">{compatData.usecases.length}</div>
        <div class="stat-label">Use Cases</div>
      </div>
    </div>
  </section>

  <div class="section-stack">
    <section class="grid cols-3">
      <a class="feature-card" href="/matrix">
        <span class="eyebrow">Matrix</span>
        <h2>Compare the whole field</h2>
        <p>Browse a full model-by-harness matrix and drill into each pairing.</p>
      </a>
      <a class="feature-card" href="/tiers">
        <span class="eyebrow">Tiers</span>
        <h2>See the aggregate leaders</h2>
        <p>Grouped S/A/B/C rankings for both models and harnesses.</p>
      </a>
      <a class="feature-card" href="/best">
        <span class="eyebrow">Best For</span>
        <h2>Pick by workflow, not hype</h2>
        <p>Get ranked recommendations with pros, cons, and why they fit.</p>
      </a>
    </section>

    <section class="section-card">
      <div class="split-header">
        <div>
          <span class="eyebrow">Featured Combos</span>
          <h2>Highest scoring stacks right now</h2>
        </div>
        <a class="button-ghost" href="/combos">View all combos</a>
      </div>
      <div class="grid cols-2" style="margin-top: 1rem;">
        {featuredCombos.map((combo) => (
          <a class="list-card" href={`/combos/${combo.slug}`}>
            <div class="list-head">
              <strong>{combo.name}</strong>
              <span class="score-chip">{combo.score.toFixed(1)}</span>
            </div>
            <p class="detail-copy">{combo.description}</p>
            <div class="meta-row">
              <span class={`pill ${combo.status}`}>{combo.status}</span>
              {combo.usecaseDetails && <span class="pill">{combo.usecaseDetails.name}</span>}
              {combo.modelDetails && <span class="pill">{combo.modelDetails.provider}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="grid cols-2">
      <div class="section-card">
        <div class="split-header">
          <div>
            <span class="eyebrow">Model Tiers</span>
            <h2>Top models by aggregate pair quality</h2>
          </div>
          <a class="button-ghost" href="/tiers/models">See model tiers</a>
        </div>
        <div class="grid" style="margin-top: 1rem;">
          {topModels.map((entry) => (
            <a class="list-card" href={`/models/${entry.item.slug}`}>
              <div class="list-head">
                <strong>{entry.item.name}</strong>
                <span class={`tier-badge tier-${entry.tier.toLowerCase()}`}>{entry.tier}</span>
              </div>
              <p class="detail-copy">{entry.item.description}</p>
              <div class="meta-row">
                <span class="score-chip">{entry.aggregateScore.toFixed(1)}</span>
                <span class="pill">{entry.comboCount} combos</span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="section-card">
        <div class="split-header">
          <div>
            <span class="eyebrow">Harness Tiers</span>
            <h2>Top harnesses across the matrix</h2>
          </div>
          <a class="button-ghost" href="/tiers/harnesses">See harness tiers</a>
        </div>
        <div class="grid" style="margin-top: 1rem;">
          {topHarnesses.map((entry) => (
            <a class="list-card" href={`/harnesses/${entry.item.slug}`}>
              <div class="list-head">
                <strong>{entry.item.name}</strong>
                <span class={`tier-badge tier-${entry.tier.toLowerCase()}`}>{entry.tier}</span>
              </div>
              <p class="detail-copy">{entry.item.description}</p>
              <div class="meta-row">
                <span class="score-chip">{entry.aggregateScore.toFixed(1)}</span>
                <span class="pill">{entry.comboCount} combos</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>
