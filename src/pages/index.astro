---
import Layout from "../layouts/Layout.astro";
import { getBestCombos } from "../data/compat";

const claudeCode = getBestCombos("claude-code", 3);
const openclaw = getBestCombos("openclaw", 3);
const budget = getBestCombos("budget", 2);
---

<Layout
  title="What model for Claude Code & OpenClaw?"
  description="Simple compatibility guide: which model should you run in Claude Code or OpenClaw?"
>
  <section class="hero">
    <h1>What model should I run?</h1>
    <p class="lede">
      Claude Code or OpenClaw — pick your tool, see the best model for it.
      Not a benchmark. Just practical recommendations.
    </p>
  </section>

  <div class="section-stack">
    <section class="section-card">
      <div class="split-header">
        <div>
          <h2>Best for Claude Code</h2>
          <p class="detail-copy">Terminal coding, refactors, repo edits.</p>
        </div>
        <a class="button" href="/best/claude-code">See all</a>
      </div>
      <div class="grid" style="margin-top: 1rem;">
        {claudeCode.map((combo) => (
          <a class="list-card" href={`/combos/${combo.slug}`}>
            <div class="list-head">
              <strong>{combo.modelDetails?.name}</strong>
              <span class="score-chip">{combo.score.toFixed(1)}</span>
            </div>
            <p class="detail-copy">{combo.notes}</p>
            <div class="meta-row">
              <span class={`pill ${combo.status}`}>{combo.status}</span>
              {combo.pros?.[0] && <span class="pill">{combo.pros[0]}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="section-card">
      <div class="split-header">
        <div>
          <h2>Best for OpenClaw</h2>
          <p class="detail-copy">Autonomous agents, skills, orchestration.</p>
        </div>
        <a class="button" href="/best/openclaw">See all</a>
      </div>
      <div class="grid" style="margin-top: 1rem;">
        {openclaw.map((combo) => (
          <a class="list-card" href={`/combos/${combo.slug}`}>
            <div class="list-head">
              <strong>{combo.modelDetails?.name}</strong>
              <span class="score-chip">{combo.score.toFixed(1)}</span>
            </div>
            <p class="detail-copy">{combo.notes}</p>
            <div class="meta-row">
              <span class={`pill ${combo.status}`}>{combo.status}</span>
              {combo.pros?.[0] && <span class="pill">{combo.pros[0]}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="section-card">
      <div class="split-header">
        <div>
          <h2>Best on a Budget</h2>
          <p class="detail-copy">Good quality, cheaper models.</p>
        </div>
        <a class="button-ghost" href="/best/budget">See all</a>
      </div>
      <div class="grid cols-2" style="margin-top: 1rem;">
        {budget.map((combo) => (
          <a class="list-card" href={`/combos/${combo.slug}`}>
            <div class="list-head">
              <strong>{combo.name}</strong>
              <span class="score-chip">{combo.score.toFixed(1)}</span>
            </div>
            <p class="detail-copy">{combo.notes}</p>
          </a>
        ))}
      </div>
    </section>
  </div>
</Layout>
