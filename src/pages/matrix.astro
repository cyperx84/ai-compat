---
import Layout from "../layouts/Layout.astro";
import { compatData } from "../data/compat";

const lookup = new Map(
  compatData.combos.map((combo) => [`${combo.model}:${combo.harness}`, combo]),
);
---

<Layout title="Compatibility Matrix" description="Full model and harness compatibility table.">
  <a href="/" class="back-link">← home</a>

  <section class="detail-card">
    <div class="detail-header">
      <div>
        <span class="eyebrow">Compatibility Matrix</span>
        <h1>All scored pairings in one view</h1>
      </div>
      <p class="lede">
        Every cell links to a combo detail page. Scores are seeded, opinionated,
        and intended to feel like practical team guidance rather than benchmark
        theater.
      </p>
    </div>
  </section>

  <section class="matrix-card" style="margin-top: 1rem;">
    <div class="split-header" style="margin-bottom: 1rem;">
      <div class="table-meta">
        {compatData.models.length} models × {compatData.harnesses.length} harnesses
      </div>
      <a class="button-ghost" href="/api/combos.json">Raw combo JSON</a>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Model</th>
            {compatData.harnesses.map((harness) => (
              <th>{harness.name}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {compatData.models.map((model) => (
            <tr>
              <td>
                <a href={`/models/${model.slug}`}><strong>{model.name}</strong></a>
                <div class="table-meta">{model.provider}</div>
              </td>
              {compatData.harnesses.map((harness) => {
                const combo = lookup.get(`${model.slug}:${harness.slug}`);
                return (
                  <td>
                    {combo ? (
                      <a class="score-chip" href={`/combos/${combo.slug}`}>
                        {combo.score.toFixed(1)}
                      </a>
                    ) : (
                      <span class="score-chip empty">n/a</span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>
