---
import Layout from "../layouts/Layout.astro";
import { compatData } from "../data/compat";

const lookup = new Map(
  compatData.combos.map((combo) => [`${combo.model}:${combo.harness}`, combo]),
);
---

<Layout title="Compatibility matrix" description="View model and harness scores in one table.">
  <a href="/" class="back-link">← home</a>

  <section class="detail-card">
    <div class="detail-header">
      <div>
        <span class="eyebrow">Matrix</span>
        <h1>Compatibility matrix</h1>
      </div>
      <p class="lede">
        Each score reflects the quality of the pairing in the shared seed data.
        Click into a score to inspect the combo detail page.
      </p>
    </div>
  </section>

  <section class="matrix-card" style="margin-top: 1rem;">
    <table>
      <thead>
        <tr>
          <th>Model</th>
          {compatData.harnesses.map((harness) => (
            <th>{harness.name}</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {compatData.models.map((model) => (
          <tr>
            <td>
              <a href={`/models/${model.slug}`}><strong>{model.name}</strong></a>
              <div class="meta-line">{model.provider}</div>
            </td>
            {compatData.harnesses.map((harness) => {
              const combo = lookup.get(`${model.slug}:${harness.slug}`);
              return (
                <td>
                  {combo ? (
                    <a class="score-chip" href={`/combos/${combo.slug}`}>
                      {combo.score.toFixed(1)}
                    </a>
                  ) : (
                    <span class="score-chip empty">n/a</span>
                  )}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</Layout>
