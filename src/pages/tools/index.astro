---
import Layout from '../../layouts/Layout.astro';
import { tools } from '../../data/tools';
import { STATUS_ICONS, STATUS_LABELS } from '../../data/types';

// Sort by type
const typeOrder = ['ide', 'editor', 'cli', 'extension', 'platform', 'agent-runtime'];
const sortedTools = [...tools].sort((a, b) => typeOrder.indexOf(a.type) - typeOrder.indexOf(b.type));

const typeLabels: Record<string, string> = {
  'ide': 'IDEs & Editors',
  'editor': 'IDEs & Editors',
  'cli': 'CLI Tools',
  'extension': 'Extensions',
  'platform': 'Platforms',
  'agent-runtime': 'Agent Runtimes',
};

// Group by type
const grouped: Record<string, typeof tools> = {};
for (const tool of sortedTools) {
  const group = typeLabels[tool.type] || 'Other';
  if (!grouped[group]) grouped[group] = [];
  grouped[group].push(tool);
}
---

<Layout title="Tools">
  <div class="page-header">
    <h1>Tools</h1>
    <p class="page-desc">AI coding tools and their model compatibility. {tools.length} tools tracked.</p>
  </div>

  <div class="search-container" id="search">
    <div class="search-wrapper">
      <input type="text" class="search-input" placeholder="Search tools..." id="toolSearch" />
    </div>
  </div>

  <div class="filter-row" id="filters">
    <button class="filter-chip active" data-filter="all">All</button>
    <button class="filter-chip" data-filter="supported">✅ Supported</button>
    <button class="filter-chip" data-filter="partial">⚠️ Partial</button>
    <button class="filter-chip" data-filter="unofficial">🔧 Unofficial</button>
  </div>

  <div id="tools-list">
    {Object.entries(grouped).map(([group, groupTools]) => (
      <div class="tool-group" data-group={group}>
        <h2 class="group-label">{group}</h2>
        <div class="grid-3">
          {groupTools.map(tool => (
            <a href={`/tools/${tool.id}`} class="card tool-card" data-name={tool.name.toLowerCase()} data-type={tool.type} data-mcp={tool.mcpSupport}>
              <div class="tool-card-header">
                <h3>{tool.name}</h3>
                <span class={`badge badge-${tool.type}`}>{tool.type}</span>
              </div>
              <p class="tool-card-desc">{tool.description}</p>
              <div class="tool-card-stats">
                <span class="stat">
                  {STATUS_ICONS[tool.mcpSupport]} MCP
                </span>
                <span class="stat">
                  {tool.models.filter(m => m.status === 'supported').length}/{tool.models.length} models
                </span>
              </div>
              <div class="tool-card-models">
                {tool.models.filter(m => m.status === 'supported').slice(0, 4).map(m => (
                  <span class="model-dot" title={m.model}></span>
                ))}
                {tool.models.filter(m => m.status === 'supported').length > 4 && (
                  <span class="more-dots">+{tool.models.filter(m => m.status === 'supported').length - 4}</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div id="no-results" style="display: none;" class="empty-state">
    <span class="empty-icon">∅</span>
    <p>No tools match your search.</p>
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 1.5rem;
  }

  .page-header h1 {
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .page-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .tool-group {
    margin-bottom: 2rem;
  }

  .group-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text);
  }

  .tool-card:hover {
    border-color: var(--accent-dim);
  }

  .tool-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .tool-card-header h3 {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .tool-card-desc {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tool-card-stats {
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-secondary);
  }

  .tool-card-models {
    display: flex;
    gap: 0.3rem;
    align-items: center;
  }

  .model-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
  }

  .more-dots {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-muted);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .badge-cli { background: rgba(59, 130, 246, 0.12); color: var(--blue); border: 1px solid rgba(59, 130, 246, 0.25); }
  .badge-ide { background: rgba(34, 197, 94, 0.12); color: var(--green); border: 1px solid rgba(34, 197, 94, 0.25); }
  .badge-extension { background: rgba(168, 85, 247, 0.12); color: #a855f7; border: 1px solid rgba(168, 85, 247, 0.25); }
  .badge-editor { background: rgba(234, 179, 8, 0.12); color: var(--yellow); border: 1px solid rgba(234, 179, 8, 0.25); }
  .badge-platform { background: rgba(236, 72, 153, 0.12); color: #ec4899; border: 1px solid rgba(236, 72, 153, 0.25); }
  .badge-agent-runtime { background: rgba(34, 211, 238, 0.12); color: var(--accent); border: 1px solid rgba(34, 211, 238, 0.25); }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-muted);
  }

  .empty-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.5rem;
  }
</style>

<script>
  const searchInput = document.getElementById('toolSearch');
  const filterChips = document.querySelectorAll('.filter-chip');
  const toolCards = document.querySelectorAll('.tool-card');
  const toolGroups = document.querySelectorAll('.tool-group');
  const noResults = document.getElementById('no-results');

  let activeFilter = 'all';

  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    filterTools(query, activeFilter);
  });

  filterChips.forEach(chip => {
    chip.addEventListener('click', () => {
      filterChips.forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      activeFilter = (chip as HTMLElement).dataset.filter || 'all';
      const query = (searchInput as HTMLInputElement)?.value.toLowerCase() || '';
      filterTools(query, activeFilter);
    });
  });

  function filterTools(query: string, filter: string) {
    let visible = 0;
    toolCards.forEach(card => {
      const el = card as HTMLElement;
      const name = el.dataset.name || '';
      const mcp = el.dataset.mcp || '';

      const matchesSearch = !query || name.includes(query);
      const matchesFilter = filter === 'all' || mcp === filter;

      el.style.display = (matchesSearch && matchesFilter) ? '' : 'none';
      if (matchesSearch && matchesFilter) visible++;
    });

    toolGroups.forEach(g => {
      const groupCards = (g as HTMLElement).querySelectorAll('.tool-card');
      const anyVisible = Array.from(groupCards).some(c => (c as HTMLElement).style.display !== 'none');
      (g as HTMLElement).style.display = anyVisible ? '' : 'none';
    });

    if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
  }
</script>
