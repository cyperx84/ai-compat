---
import Layout from '../../layouts/Layout.astro';
import { tools } from '../../data/tools';
import { models } from '../../data/models';
import { STATUS_ICONS, STATUS_LABELS, STATUS_COLORS } from '../../data/types';

export function getStaticPaths() {
  return tools.map(tool => ({
    params: { id: tool.id },
    props: { tool },
  }));
}

const { tool } = Astro.props;

// Enrich model compat with full model data
const enrichedModels = tool.models.map(compat => {
  const model = models.find(m => m.id === compat.model);
  return { ...compat, modelData: model };
});
---

<Layout title={tool.name}>
  <a href="/tools" class="back-link">← back to tools</a>

  <div class="detail-header">
    <h1>{tool.name}</h1>
    <div class="detail-meta">
      <span class="badge badge-{tool.type === 'cli' ? 'unofficial' : tool.type === 'ide' ? 'supported' : 'partial'}">{tool.type}</span>
      <span class="badge badge-{tool.mcpSupport}">
        {STATUS_ICONS[tool.mcpSupport]} MCP: {STATUS_LABELS[tool.mcpSupport]}
      </span>
      {tool.website && <a href={tool.website} target="_blank" rel="noopener" class="ext-link">website ↗</a>}
    </div>
  </div>

  <p class="detail-description">{tool.description}</p>
  {tool.mcpNotes && (
    <p class="detail-description mono" style="font-size: 0.8rem; color: var(--text-muted);">
      MCP: {tool.mcpNotes}
    </p>
  )}

  <section class="section">
    <h2>Model Compatibility</h2>
    <table>
      <thead>
        <tr>
          <th>Model</th>
          <th>Provider</th>
          <th>Status</th>
          <th>Since</th>
          <th>Evidence</th>
        </tr>
      </thead>
      <tbody>
        {enrichedModels.map(({ model, status, notes, since, evidence, modelData }) => (
          <tr>
            <td>
              {modelData ? (
                <a href={`/models/${model}`}>{modelData.name}</a>
              ) : (
                <span class="mono">{model}</span>
              )}
            </td>
            <td class="text-muted">{modelData?.provider || '—'}</td>
            <td>
              <span class={`badge badge-${status}`}>
                {STATUS_ICONS[status]} {STATUS_LABELS[status]}
              </span>
              {notes && <span class="compat-note">{notes}</span>}
            </td>
            <td class="text-muted mono">{since || '—'}</td>
            <td>
              {evidence && (
                <div class="evidence-links">
                  {evidence.map(e => (
                    <a href={e.url} target="_blank" rel="noopener" class="evidence-link">{e.label}</a>
                  ))}
                </div>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</Layout>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    font-weight: 500;
  }

  .badge-cli { background: rgba(59, 130, 246, 0.12); color: var(--blue); border: 1px solid rgba(59, 130, 246, 0.25); }
  .badge-ide { background: rgba(34, 197, 94, 0.12); color: var(--green); border: 1px solid rgba(34, 197, 94, 0.25); }
  .badge-extension { background: rgba(168, 85, 247, 0.12); color: #a855f7; border: 1px solid rgba(168, 85, 247, 0.25); }
  .badge-editor { background: rgba(234, 179, 8, 0.12); color: var(--yellow); border: 1px solid rgba(234, 179, 8, 0.25); }
  .badge-platform { background: rgba(236, 72, 153, 0.12); color: #ec4899; border: 1px solid rgba(236, 72, 153, 0.25); }
  .badge-agent-runtime { background: rgba(34, 211, 238, 0.12); color: var(--accent); border: 1px solid rgba(34, 211, 238, 0.25); }

  .ext-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .ext-link:hover {
    color: var(--accent);
  }

  .compat-note {
    display: block;
    font-size: 0.65rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
    font-family: var(--font-mono);
  }

  .text-muted {
    color: var(--text-muted);
  }
</style>
