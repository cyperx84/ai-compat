---
import Layout from "../../layouts/Layout.astro";
import { getCombosForHarness, getHarnessRankings } from "../../data/compat";

const rankings = getHarnessRankings();
---

<Layout title="Harnesses" description="Browse ranked harnesses in the ai-compat dataset.">
  <a href="/" class="back-link">← home</a>

  <section class="detail-card">
    <div class="detail-header">
      <div>
        <span class="eyebrow">Harnesses</span>
        <h1>Harnesses</h1>
      </div>
      <a class="button-ghost" href="/tiers/harnesses">Tier list</a>
    </div>
    <p class="lede">
      CLI agents, IDEs, and agent runtimes ranked by aggregate pair quality
      across the shared matrix.
    </p>
  </section>

  <section class="grid cols-2" style="margin-top: 1rem;">
    {rankings.map((entry) => (
      <a class="list-card" href={`/harnesses/${entry.item.slug}`}>
        <div class="list-head">
          <strong>{entry.item.name}</strong>
          <span class={`tier-badge tier-${entry.tier.toLowerCase()}`}>{entry.tier}</span>
        </div>
        <p class="detail-copy">{entry.item.description}</p>
        <div class="meta-row">
          <span class={`pill ${entry.item.status}`}>{entry.item.status}</span>
          <span class="pill">{entry.item.type}</span>
          <span class="score-chip">{entry.aggregateScore.toFixed(1)}</span>
          <span class="pill">{getCombosForHarness(entry.item.slug).length} combos</span>
        </div>
      </a>
    ))}
  </section>
</Layout>
