---
import Layout from "../../layouts/Layout.astro";
import { compatData, getCombosForHarness, getTierForScore, getUsecasesForCombo } from "../../data/compat";

export function getStaticPaths() {
  return compatData.harnesses.map((harness) => ({
    params: { slug: harness.slug },
    props: { harness },
  }));
}

const { harness } = Astro.props;
const combos = getCombosForHarness(harness.slug).sort((left, right) => right.score - left.score);
const aggregateScore =
  combos.reduce((sum, combo) => sum + combo.score, 0) / Math.max(combos.length, 1);
const tier = getTierForScore(aggregateScore);
---

<Layout title={harness.name} description={harness.description}>
  <a href="/harnesses" class="back-link">← harnesses</a>

  <section class="detail-card">
    <div class="detail-header">
      <div>
        <span class="eyebrow">{harness.provider}</span>
        <h1>{harness.name}</h1>
      </div>
      <div class="detail-meta">
        <span class={`tier-badge tier-${tier.toLowerCase()}`}>{tier}</span>
        <span class="pill">{harness.type}</span>
        <span class={`pill ${harness.status}`}>{harness.status}</span>
      </div>
    </div>
    <p class="lede">{harness.description}</p>
    <div class="meta-row" style="margin-top: 1rem;">
      <span class="score-chip">{aggregateScore.toFixed(1)} avg</span>
      <span class="pill">{combos.length} combos scored</span>
    </div>
    <div class="tag-row">
      {harness.features.map((feature: string) => (
        <span class="tag">{feature}</span>
      ))}
    </div>
    {harness.website && (
      <div class="button-row" style="margin-top: 1rem;">
        <a class="button-ghost" href={harness.website} target="_blank" rel="noreferrer">Harness website</a>
      </div>
    )}
  </section>

  <section class="section-card" style="margin-top: 1rem;">
    <h2>Best model pairings</h2>
    <div class="grid" style="margin-top: 1rem;">
      {combos.map((combo) => (
        <a class="list-card" href={`/combos/${combo.slug}`}>
          <div class="list-head">
            <strong>{combo.name}</strong>
            <span class="score-chip">{combo.score.toFixed(1)}</span>
          </div>
          <p class="detail-copy">{combo.description}</p>
          <div class="meta-row">
            <span class={`pill ${combo.status}`}>{combo.status}</span>
            {getUsecasesForCombo(combo).slice(0, 3).map((usecase) => (
              <span class="pill">{usecase.name}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
