---
import Layout from "../../layouts/Layout.astro";
import { compatData, getBestCombos } from "../../data/compat";

const spotlight = compatData.usecases.map((usecase) => ({
  usecase,
  combos: getBestCombos(usecase.id, 3),
}));
---

<Layout title="Best For" description="Recommendations by workflow and use case.">
  <a href="/" class="back-link">← home</a>

  <section class="detail-card">
    <span class="eyebrow">Best For</span>
    <h1>Recommendations by workflow</h1>
    <p class="lede">
      Pick a page based on the work you need done, not just the model name.
      Each ranking explains why the combo fits, where it shines, and what the
      tradeoffs look like.
    </p>
  </section>

  <section class="grid cols-2" style="margin-top: 1rem;">
    {spotlight.map(({ usecase, combos }) => (
      <a class="list-card" href={`/best/${usecase.id}`}>
        <div class="list-head">
          <strong>{usecase.name}</strong>
          <span class="pill">{combos.length} picks</span>
        </div>
        <p class="detail-copy">{usecase.description}</p>
        <div class="meta-row">
          {combos.slice(0, 2).map((combo) => (
            <span class="pill">{combo.name}</span>
          ))}
        </div>
      </a>
    ))}
  </section>
</Layout>
