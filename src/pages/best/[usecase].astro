---
import Layout from "../../layouts/Layout.astro";
import { compatData, getBestCombos, getUsecase } from "../../data/compat";

export function getStaticPaths() {
  return compatData.usecases.map((usecase) => ({
    params: { usecase: usecase.id },
  }));
}

const { usecase: usecaseId } = Astro.params;
const usecase = getUsecase(usecaseId ?? "");
const combos = getBestCombos(usecaseId, 8);
---

<Layout title={`Best for ${usecase?.name ?? usecaseId}`} description={usecase?.description}>
  <a href="/" class="back-link">← home</a>

  <section class="detail-card">
    <h1>Best for {usecase?.name}</h1>
    <p class="lede">{usecase?.description}</p>
  </section>

  <div class="section-stack" style="margin-top: 1rem;">
    {combos.map((combo, index) => (
      <a class="list-card" href={`/combos/${combo.slug}`}>
        <div class="list-head">
          <strong>#{index + 1} {combo.modelDetails?.name}</strong>
          <span class="score-chip">{combo.score.toFixed(1)}</span>
        </div>
        <p class="detail-copy">{combo.notes}</p>
        {combo.pros && combo.pros.length > 0 && (
          <div class="meta-row" style="margin-top: 0.6rem;">
            <span class="eyebrow" style="margin-right: 0.5rem;">Pros</span>
            {combo.pros.map(p => <span class="pill">{p}</span>)}
          </div>
        )}
        {combo.cons && combo.cons.length > 0 && (
          <div class="meta-row">
            <span class="eyebrow" style="margin-right: 0.5rem;">Cons</span>
            {combo.cons.map(c => <span class="pill">{c}</span>)}
          </div>
        )}
        <div class="meta-row">
          <span class={`pill ${combo.status}`}>{combo.status}</span>
          <span class="pill">{combo.harnessDetails?.name}</span>
        </div>
      </a>
    ))}
  </div>
</Layout>
