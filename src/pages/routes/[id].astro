---
import Layout from '../../layouts/Layout.astro';
import { routes } from '../../data/routes';
import { STATUS_ICONS, STATUS_LABELS } from '../../data/types';

export function getStaticPaths() {
  return routes.map(route => ({
    params: { id: route.id },
    props: { route },
  }));
}

const { route } = Astro.props;
---

<Layout title={route.provider}>
  <a href="/routes" class="back-link">← back to routes</a>

  <div class="detail-header">
    <h1>{route.provider}</h1>
    {route.website && <a href={route.website} target="_blank" rel="noopener" class="ext-link">website ↗</a>}
  </div>

  <p class="detail-description">{route.description}</p>

  <section class="section">
    <h2>Provider Compatibility</h2>
    <div class="matrix-scroll">
      <table>
        <thead>
          <tr>
            <th>Provider</th>
            <th>Model</th>
            <th>Status</th>
            <th>Notes</th>
            <th>Evidence</th>
          </tr>
        </thead>
        <tbody>
          {route.routes.map(entry => (
            <tr>
              <td class="mono">{entry.provider}</td>
              <td class="text-muted mono">{entry.model || 'All models'}</td>
              <td>
                <span class={`badge badge-${entry.status}`}>
                  {STATUS_ICONS[entry.status]} {STATUS_LABELS[entry.status]}
                </span>
              </td>
              <td class="text-muted mono" style="font-size: 0.75rem;">{entry.notes || '—'}</td>
              <td>
                {entry.evidence && (
                  <div class="evidence-links">
                    {entry.evidence.map(e => (
                      <a href={e.url} target="_blank" rel="noopener" class="evidence-link">{e.label}</a>
                    ))}
                  </div>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>

<style>
  .ext-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .ext-link:hover {
    color: var(--accent);
  }

  .matrix-scroll {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-secondary);
  }

  .text-muted { color: var(--text-muted); }
</style>
