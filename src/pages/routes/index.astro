---
import Layout from '../../layouts/Layout.astro';
import { routes } from '../../data/routes';
import { STATUS_ICONS, STATUS_LABELS } from '../../data/types';
---

<Layout title="Routes">
  <div class="page-header">
    <h1>Provider Routes</h1>
    <p class="page-desc">Which AI providers work through which routers and platforms. {routes.length} routes tracked.</p>
  </div>

  <div id="routes-list">
    {routes.map(route => (
      <section class="section route-section">
        <div class="route-header">
          <div>
            <h2 style="margin-bottom: 0.25rem;">{route.provider}</h2>
            <p class="route-desc">{route.description}</p>
          </div>
          {route.website && (
            <a href={route.website} target="_blank" rel="noopener" class="ext-link">website ↗</a>
          )}
        </div>

        <div class="matrix-scroll">
          <table>
            <thead>
              <tr>
                <th>Provider</th>
                <th>Model</th>
                <th>Status</th>
                <th>Notes</th>
                <th>Evidence</th>
              </tr>
            </thead>
            <tbody>
              {route.routes.map(entry => (
                <tr>
                  <td><span class="provider-name">{entry.provider}</span></td>
                  <td class="text-muted mono">{entry.model || 'All models'}</td>
                  <td>
                    <span class={`badge badge-${entry.status}`}>
                      {STATUS_ICONS[entry.status]} {STATUS_LABELS[entry.status]}
                    </span>
                  </td>
                  <td class="text-muted mono" style="font-size: 0.75rem;">{entry.notes || '—'}</td>
                  <td>
                    {entry.evidence && (
                      <div class="evidence-links">
                        {entry.evidence.map(e => (
                          <a href={e.url} target="_blank" rel="noopener" class="evidence-link">{e.label}</a>
                        ))}
                      </div>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))}
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 1.5rem;
  }

  .page-header h1 {
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .page-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .route-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .route-section h2 {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
  }

  .route-section h2::before {
    content: none;
  }

  .route-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    max-width: 600px;
  }

  .ext-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .ext-link:hover {
    color: var(--accent);
  }

  .provider-name {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.8rem;
  }

  .matrix-scroll {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-secondary);
  }

  .text-muted { color: var(--text-muted); }
</style>
