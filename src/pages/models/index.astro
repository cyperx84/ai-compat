---
import Layout from "../../layouts/Layout.astro";
import { getCombosForModel, getModelRankings } from "../../data/compat";

const rankings = getModelRankings();
---

<Layout title="Models" description="Browse ranked models in the ai-compat dataset.">
  <a href="/" class="back-link">← home</a>

  <section class="detail-card">
    <div class="detail-header">
      <div>
        <span class="eyebrow">Models</span>
        <h1>Models</h1>
      </div>
      <a class="button-ghost" href="/tiers/models">Tier list</a>
    </div>
    <p class="lede">
      Each entry includes provider, context window, aggregate combo score, and
      links to its strongest harness pairings.
    </p>
  </section>

  <section class="grid cols-2" style="margin-top: 1rem;">
    {rankings.map((entry) => (
      <a class="list-card" href={`/models/${entry.item.slug}`}>
        <div class="list-head">
          <strong>{entry.item.name}</strong>
          <span class={`tier-badge tier-${entry.tier.toLowerCase()}`}>{entry.tier}</span>
        </div>
        <p class="detail-copy">{entry.item.description}</p>
        <div class="meta-row">
          <span class="pill">{entry.item.provider}</span>
          <span class="pill">{entry.item.contextWindow}</span>
          <span class="score-chip">{entry.aggregateScore.toFixed(1)}</span>
          <span class="pill">{getCombosForModel(entry.item.slug).length} combos</span>
        </div>
      </a>
    ))}
  </section>
</Layout>
