---
import Layout from "../../layouts/Layout.astro";
import { compatData, getCombosForModel } from "../../data/compat";
---

<Layout title="Models" description="Browse models included in the ai-compat dataset.">
  <a href="/" class="back-link">← home</a>

  <section class="detail-card">
    <span class="eyebrow">Models</span>
    <h1>Models</h1>
    <p class="lede">Every entry links to a detail page with its best harness pairings.</p>
  </section>

  <section class="grid cols-2" style="margin-top: 1rem;">
    {compatData.models.map((model) => (
      <a class="list-card" href={`/models/${model.slug}`}>
        <div class="list-head">
          <strong>{model.name}</strong>
          <span class="pill">{model.provider}</span>
        </div>
        <p class="detail-copy">{model.description}</p>
        <div class="meta-row">
          <span class="pill">{model.contextWindow}</span>
          <span class="pill">{getCombosForModel(model.slug).length} combos</span>
        </div>
      </a>
    ))}
  </section>
</Layout>
