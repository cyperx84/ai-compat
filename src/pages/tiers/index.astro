---
import Layout from "../../layouts/Layout.astro";
import { getHarnessRankings, getModelRankings } from "../../data/compat";

const topModels = getModelRankings().slice(0, 5);
const topHarnesses = getHarnessRankings().slice(0, 5);
---

<Layout title="Tier Lists" description="Aggregate tier rankings for models and harnesses.">
  <a href="/" class="back-link">← home</a>

  <section class="detail-card">
    <span class="eyebrow">Tier Lists</span>
    <h1>Aggregate rankings for the matrix</h1>
    <p class="lede">
      Tiers group items by average combo score: S for exceptional, A for great,
      B for solid, and C for usable. Each list links into the underlying detail
      pages and best-performing combos.
    </p>
  </section>

  <section class="grid cols-2" style="margin-top: 1rem;">
    <div class="section-card">
      <div class="split-header">
        <div>
          <span class="eyebrow">Models</span>
          <h2>Model tier list</h2>
        </div>
        <a class="button-ghost" href="/tiers/models">Open</a>
      </div>
      <div class="grid" style="margin-top: 1rem;">
        {topModels.map((entry) => (
          <a class="list-card" href={`/models/${entry.item.slug}`}>
            <div class="list-head">
              <strong>{entry.item.name}</strong>
              <span class={`tier-badge tier-${entry.tier.toLowerCase()}`}>{entry.tier}</span>
            </div>
            <p class="detail-copy">{entry.item.description}</p>
            <div class="meta-row">
              <span class="score-chip">{entry.aggregateScore.toFixed(1)}</span>
              <span class="pill">{entry.comboCount} combos</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="section-card">
      <div class="split-header">
        <div>
          <span class="eyebrow">Harnesses</span>
          <h2>Harness tier list</h2>
        </div>
        <a class="button-ghost" href="/tiers/harnesses">Open</a>
      </div>
      <div class="grid" style="margin-top: 1rem;">
        {topHarnesses.map((entry) => (
          <a class="list-card" href={`/harnesses/${entry.item.slug}`}>
            <div class="list-head">
              <strong>{entry.item.name}</strong>
              <span class={`tier-badge tier-${entry.tier.toLowerCase()}`}>{entry.tier}</span>
            </div>
            <p class="detail-copy">{entry.item.description}</p>
            <div class="meta-row">
              <span class="score-chip">{entry.aggregateScore.toFixed(1)}</span>
              <span class="pill">{entry.comboCount} combos</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
