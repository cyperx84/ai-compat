---
import Layout from "../../layouts/Layout.astro";
import { getBestCombos } from "../../data/compat";

const combos = getBestCombos(undefined, 200);
---

<Layout title="Combos" description="Browse model and harness combinations in the ai-compat dataset.">
  <a href="/" class="back-link">← home</a>

  <section class="detail-card">
    <div class="detail-header">
      <div>
        <span class="eyebrow">Combos</span>
        <h1>Combos</h1>
      </div>
      <a class="button-ghost" href="/api/combos.json">JSON</a>
    </div>
    <p class="lede">
      The full ranked matrix, sorted by overall pair score. Use the best-for
      pages when you want rankings filtered to a specific workflow.
    </p>
  </section>

  <section class="grid cols-2" style="margin-top: 1rem;">
    {combos.map((combo) => (
      <a class="list-card" href={`/combos/${combo.slug}`}>
        <div class="list-head">
          <strong>{combo.name}</strong>
          <span class="score-chip">{combo.score.toFixed(1)}</span>
        </div>
        <p class="detail-copy">{combo.description}</p>
        <div class="meta-row">
          <span class={`pill ${combo.status}`}>{combo.status}</span>
          {combo.usecaseDetails && <span class="pill">{combo.usecaseDetails.name}</span>}
          {combo.modelDetails && <span class="pill">{combo.modelDetails.provider}</span>}
        </div>
      </a>
    ))}
  </section>
</Layout>
